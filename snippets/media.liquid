{% if media %}

    aspect_ratio: aspect_ratio,
                    media_style: media_style
                    radius: radius,
    {% comment %} <img src="{{ media | img_url: '300x' }}" width="" height="auto" alt="{{ media.alt }}"> {% endcomment %}
    
    {% comment %} <img src="{{ media |  image_url: width: '500px', height:  auto }}" alt="Image"> {% endcomment %}

    {%  capture media_style %} 
        border-radius: {{ radius}} px;
        aspect_ratio: {{ aspect_ratio }};
        object-fit: {{ media_style }};
        height: auto;
    {% endcapture %}

    {{ 
        media 
        | image_url: width: '700px' 
        | image_tag:
          class: 'image_style',
          fetchpriority: "high",
          loading: 'lazy',
          style: media_style


    }}

{%  else %}
    {{ 'blog-apparel-1' | placeholder_svg_tag: 'icon' }}
{% endif %}